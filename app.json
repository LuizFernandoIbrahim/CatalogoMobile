{
  "expo": {
    "name": "Oficina de Marias",
    "slug": "oficina-de-marias",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAF5EE"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.oficinadmarias.app",
      "requireFullScreen": true,
      "config": {
        "googleMapsApiKey": "SUA_API_KEY_IOS_AQUI"
      },
      "infoPlist": {
        "NSFaceIDUsageDescription": "Use o Face ID para acessar a Oficina de Marias com segurança.",
        "NSLocationWhenInUseUsageDescription": "Usamos sua localização para mostrar sua posição no mapa da loja.",
        "UISupportedInterfaceOrientations": ["UIInterfaceOrientationPortrait"],
        "UISupportedInterfaceOrientations~ipad": ["UIInterfaceOrientationPortrait"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FAF5EE"
      },
      "package": "com.oficinadmarias.app",
      "screenOrientation": "portrait",
      "config": {
        "googleMaps": {
          "apiKey": "SUA_API_KEY_ANDROID_AQUI"
        }
      },
      "permissions": [
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "plugins": [
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Use o Face ID para acessar a Oficina de Marias com segurança."
        }
      ],
      "expo-screen-orientation",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Usamos sua localização para mostrar sua posição no mapa da loja."
        }
      ]
    ]
  }
}
